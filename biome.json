{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": [
			"apps/**/*.ts",
			"apps/**/*.tsx",
			"packages/**/*.ts",
			"packages/**/*.tsx",
			"*.json",
			"!**/node_modules",
			"!**/.next",
			"!**/dist",
			"!**/migrations"
		]
	}
}
