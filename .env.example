# === REQUIRED: Database ===
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL_TEST=postgresql://user:password@host:5432/dbname_test?sslmode=require

# === REQUIRED: Auth ===
AUTH_SECRET=                          # generate with: npx auth secret
AUTH_URL=http://localhost:3000
AUTH_RESEND_KEY=re_test_xxx           # magic link key — in dev mode the link is logged to console

# === REQUIRED: Email (non-crashing stub) ===
RESEND_API_KEY=re_test_xxx            # emails will not deliver but server will not crash
RESEND_FROM_ADDRESS=onboarding@resend.dev

# === REQUIRED: Domain ===
NEXT_PUBLIC_DOMAIN_MODE=azure-default
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# === OPTIONAL: Supabase Storage (photo uploads) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=

# === OPTIONAL: Microsoft Entra ID (Azure SSO) ===
AUTH_MICROSOFT_ENTRA_ID_CLIENT_ID=
AUTH_MICROSOFT_ENTRA_ID_CLIENT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=
# Legacy key names (kept for compatibility):
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
